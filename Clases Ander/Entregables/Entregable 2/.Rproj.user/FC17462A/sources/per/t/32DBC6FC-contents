kable(resultados_az, digits = 3, caption = "AP por azimuth")

ggplot(resultados_az, aes(x = Azimuth, y = AP, color = Clase)) +
  geom_line(size = 1.1) +
  geom_point(size = 3) +
  scale_color_manual(values = c("1" = "#3498db", "7" = "#e74c3c"),
