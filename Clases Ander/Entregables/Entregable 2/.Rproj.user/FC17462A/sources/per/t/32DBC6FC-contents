# Crear bins de azimuth absoluto
X_validation_eng$abs_az <- abs(X_validation_eng$azimuth_sc)
bins_az <- c(0, 0.1, 0.2, 0.3, 0.5, max(X_validation_eng$abs_az))

X_validation_eng$bin_az <- cut(X_validation_eng$abs_az,
                                 breaks = bins_az,
                                 include.lowest = TRUE)

