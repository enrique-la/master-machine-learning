geom_density(alpha = 0.5) +
scale_fill_manual(values = c("interstation" = "#2E86AB", "stop" = "#A23B72")) +
labs(
title = "Densidad de probabilidad de energía consumida",
x = "Energía consumida (kWh)",
y = "Densidad",
fill = "Evento"
)
grid.arrange(p1, p2, ncol = 2)
### Test estadístico para diferencia de energía
```{r test_energia}
# Separar datos por tipo de evento
energia_interstation <- df_filtered %>%
filter(event == "interstation") %>%
pull(eaux_train_ac)
energia_stop <- df_filtered %>%
filter(event == "stop") %>%
pull(eaux_train_ac)
# Test de normalidad (Shapiro-Wilk en muestra aleatoria)
set.seed(123)
muestra_inter <- sample(energia_interstation, min(5000, length(energia_interstation)))
muestra_stop <- sample(energia_stop, min(5000, length(energia_stop)))
shapiro_inter <- shapiro.test(muestra_inter)
shapiro_stop <- shapiro.test(muestra_stop)
cat("Test de normalidad Shapiro-Wilk:\n")
cat("- Interstation: p-valor =", shapiro_inter$p.value, "\n")
cat("- Stop: p-valor =", shapiro_stop$p.value, "\n\n")
test_wilcox_energia <- wilcox.test(energia_interstation, energia_stop)
test_wilcox_energia <- wilcox.test(energia_interstation, energia_stop)
cat("Test de Wilcoxon (Mann-Whitney U) para energía consumida:\n")
cat("- Estadístico W:", test_wilcox_energia$statistic, "\n")
cat("- P-valor:", format.pval(test_wilcox_energia$p.value), "\n")
# Calcular tamaño del efecto (diferencia de medianas)
diff_mediana <- median(energia_interstation) - median(energia_stop)
cat("- Diferencia de medianas:", round(diff_mediana, 3), "kWh\n")
# Intervalo de confianza
cat("\n")
if (test_wilcox_energia$p.value < 0.05) {
cat("✓ CONCLUSIÓN: Existe diferencia SIGNIFICATIVA en el consumo energético\n")
cat("  entre eventos 'interstation' y 'stop' (p < 0.05)\n")
} else {
cat("✗ CONCLUSIÓN: NO existe diferencia significativa en el consumo energético\n")
cat("  entre eventos 'interstation' y 'stop' (p >= 0.05)\n")
}
```{r analisis_potencia}
# Calcular potencia en kW
df_filtered <- df_filtered %>%
mutate(potencia_kw = eaux_train_ac / (event_duration / 3600))
# Estadísticas descriptivas por tipo de evento
stats_potencia <- df_filtered %>%
group_by(event) %>%
summarise(
