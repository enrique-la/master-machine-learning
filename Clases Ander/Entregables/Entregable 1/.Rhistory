# Introducción
Este documento presenta el análisis completo de la modelización de la energía consumida en los equipos auxiliares de trenes, en función de los tiempos de funcionamiento de los componentes HVAC (calefacción, ventilación y aire acondicionado).
## Objetivo
Modelizar la energía consumida en auxiliares en función de los tiempos de funcionamiento de los componentes de HVAC, utilizando datos de septiembre 2019.
---
# 1. Carga de datos (0.5 puntos)
Primero cargamos las librerías necesarias y los datos.
```{r librerias}
# Librerías necesarias
library(tidyverse)      # Manipulación y visualización de datos
library(lubridate)      # Manejo de fechas
library(scales)         # Escalas para gráficos
library(gridExtra)      # Múltiples gráficos
library(broom)          # Limpieza de resultados de modelos
library(caret)          # Machine Learning
library(randomForest)   # Random Forest
library(xgboost)        # XGBoost
library(knitr)          # Tablas bonitas
library(kableExtra)     # Más opciones para tablas
# Configuración de tema para gráficos
theme_set(theme_minimal(base_size = 12))
# Configuración de tema para gráficos
theme_set(theme_minimal(base_size = 12))
```{r carga_datos}
# Cargar los datos
load("Entregable1.RData")
# Verificar la estructura de los datos
cat("Dimensiones del dataframe:", dim(df)[1], "filas y", dim(df)[2], "columnas\n\n")
# Mostrar primeras filas
head(df) %>%
kable(caption = "Primeras 6 observaciones del dataset") %>%
kable_styling(bootstrap_options = c("striped", "hover", "condensed"))
# Resumen estadístico
cat("\nResumen estadístico de las variables:\n")
summary(df)
# Datos originales
n_original <- nrow(df)
cat("Número de observaciones originales:", n_original, "\n")
# Filtrar eventos de más de 600 segundos
df_filtered <- df %>%
filter(event_duration <= 600)
n_despues_duracion <- nrow(df_filtered)
cat("Después de eliminar eventos > 600s:", n_despues_duracion,
"(eliminados:", n_original - n_despues_duracion, ")\n")
# Filtrar eventos de mantenimiento
df_filtered <- df_filtered %>%
filter(event != "MAINTENANCE")
n_final <- nrow(df_filtered)
cat("Después de eliminar 'maintenance':", n_final,
"(eliminados:", n_despues_duracion - n_final, ")\n")
View(df)
cat("\n✓ Total de observaciones eliminadas:", n_original - n_final,
"(", round((n_original - n_final)/n_original*100, 2), "% del total)\n")
cat("✓ Observaciones finales para análisis:", n_final, "\n")
# Verificar tipos de eventos restantes
cat("\nDistribución de eventos después del filtrado:\n")
table(df_filtered$event)
# Estadísticas descriptivas por tipo de evento
stats_energia <- df_filtered %>%
group_by(event) %>%
summarise(
n = n(),
media = mean(eaux_train_ac, na.rm = TRUE),
mediana = median(eaux_train_ac, na.rm = TRUE),
desv_std = sd(eaux_train_ac, na.rm = TRUE),
min = min(eaux_train_ac, na.rm = TRUE),
max = max(eaux_train_ac, na.rm = TRUE)
)
stats_energia %>%
kable(caption = "Estadísticas de energía consumida (kWh) por tipo de evento",
digits = 3) %>%
kable_styling(bootstrap_options = c("striped", "hover"))
# Estadísticas descriptivas por tipo de evento
stats_energia <- df_filtered %>%
group_by(event) %>%
summarise(
n = n(),
media = mean(eaux_train_ac, na.rm = TRUE),
mediana = median(eaux_train_ac, na.rm = TRUE),
desv_std = sd(eaux_train_ac, na.rm = TRUE),
min = min(eaux_train_ac, na.rm = TRUE),
max = max(eaux_train_ac, na.rm = TRUE)
)
stats_energia %>%
kable(caption = "Estadísticas de energía consumida (kWh) por tipo de evento",
digits = 3) %>%
kable_styling(bootstrap_options = c("striped", "hover"))
# Visualización
p1 <- ggplot(df_filtered, aes(x = event, y = eaux_train_ac, fill = event)) +
geom_violin(alpha = 0.6) +
geom_boxplot(width = 0.2, alpha = 0.8) +
scale_fill_manual(values = c("interstation" = "#2E86AB", "stop" = "#A23B72")) +
labs(
title = "Distribución de energía consumida por tipo de evento",
x = "Tipo de evento",
