kable(caption = "Estadísticas de potencia (kW) por tipo de evento",
digits = 3) %>%
kable_styling(bootstrap_options = c("striped", "hover"))
# Visualización
p3 <- ggplot(df_filtered, aes(x = event, y = potencia_kw, fill = event)) +
geom_violin(alpha = 0.6) +
geom_boxplot(width = 0.2, alpha = 0.8) +
scale_fill_manual(values = c("interstation" = "#2E86AB", "stop" = "#A23B72")) +
labs(
title = "Distribución de potencia por tipo de evento",
x = "Tipo de evento",
y = "Potencia (kW)",
fill = "Evento"
) +
theme(legend.position = "none")
p4 <- ggplot(df_filtered, aes(x = potencia_kw, fill = event)) +
geom_density(alpha = 0.5) +
scale_fill_manual(values = c("interstation" = "#2E86AB", "stop" = "#A23B72")) +
labs(
title = "Densidad de probabilidad de potencia",
x = "Potencia (kW)",
y = "Densidad",
fill = "Evento"
) +
xlim(0, quantile(df_filtered$potencia_kw, 0.99, na.rm = TRUE))
grid.arrange(p3, p4, ncol = 2)
# Separar datos por tipo de evento
potencia_interstation <- df_filtered %>%
filter(event == "interstation") %>%
pull(potencia_kw)
potencia_stop <- df_filtered %>%
filter(event == "stop") %>%
pull(potencia_kw)
# Test de Wilcoxon para potencia
test_wilcox_potencia <- wilcox.test(potencia_interstation, potencia_stop)
cat("Test de Wilcoxon (Mann-Whitney U) para potencia:\n")
cat("- Estadístico W:", test_wilcox_potencia$statistic, "\n")
cat("- P-valor:", format.pval(test_wilcox_potencia$p.value), "\n")
# Calcular tamaño del efecto
diff_mediana_pot <- median(potencia_interstation, na.rm = TRUE) -
median(potencia_stop, na.rm = TRUE)
cat("- Diferencia de medianas:", round(diff_mediana_pot, 3), "kW\n\n")
if (test_wilcox_potencia$p.value < 0.05) {
cat("✓ CONCLUSIÓN: Existe diferencia SIGNIFICATIVA en la potencia\n")
cat("  entre eventos 'interstation' y 'stop' (p < 0.05)\n")
} else {
cat("✗ CONCLUSIÓN: NO existe diferencia significativa en la potencia\n")
cat("  entre eventos 'interstation' y 'stop' (p >= 0.05)\n")
}
if (test_wilcox_potencia$p.value < 0.05) {
cat("✓ CONCLUSIÓN: Existe diferencia SIGNIFICATIVA en la potencia\n")
cat("  entre eventos 'interstation' y 'stop' (p < 0.05)\n")
} else {
cat("✗ CONCLUSIÓN: NO existe diferencia significativa en la potencia\n")
cat("  entre eventos 'interstation' y 'stop' (p >= 0.05)\n")
}
**Interpretación de la comparativa:**
Los tests estadísticos nos permiten determinar si las diferencias observadas entre los dos tipos de eventos son estadísticamente significativas o simplemente producto del azar. Los eventos `interstation` representan el consumo entre estaciones (tren en movimiento), mientras que `stop` representa paradas en estaciones.
