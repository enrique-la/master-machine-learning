title: "Modelización de la energía consumida en auxiliares"
```{r setup, include=FALSE}
knitr::opts_chunk$set(
echo = TRUE,
warning = FALSE,
message = FALSE,
fig.width = 6,
fig.height = 4,
fig.align = "center"
)
options(knitr.table.format = "latex")
library(tidyverse)
library(lubridate)
library(broom)
library(caret)
library(caret)
library(randomForest)
library(xgboost)
library(knitr)
library(kableExtra)
library(lmtest)
set.seed(123)
load("Entregable1.RData")
# Verificar nombre del objeto cargado
if (!exists("df")) {
df <- get(ls()[sapply(ls(), function(x) is.data.frame(get(x)))][1])
}
df_filtered <- df %>%
filter(!is.na(event_duration),
event_duration > 0,
event_duration <= 600,
tolower(trimws(as.character(event))) != "maintenance") %>%
mutate(event_lower = tolower(trimws(as.character(event)))) %>%
filter(complete.cases(.))
View(df_filtered)
stats_energia <- df_filtered %>%
group_by(event_lower) %>%
summarise(
n = n(),
Media = mean(eaux_train_ac),
Mediana = median(eaux_train_ac),
`Desv. Std` = sd(eaux_train_ac)
)
kable(stats_energia,
caption = "Estadísticas de energía consumida por evento",
digits = 3,
booktabs = TRUE) %>%
kable_styling(latex_options = c("hold_position"), font_size = 10)
# Test estadístico
energia_inter <- df_filtered %>% filter(event_lower == "interstation") %>% pull(eaux_train_ac)
energia_stop <- df_filtered %>% filter(event_lower == "stop") %>% pull(eaux_train_ac)
test_energia <- wilcox.test(energia_inter, energia_stop)
df_filtered <- df_filtered %>%
mutate(potencia_kw = ifelse(event_duration > 1,
eaux_train_ac / (event_duration / 3600),
NA_real_))
df_potencia <- df_filtered %>% filter(!is.na(potencia_kw))
stats_potencia <- df_potencia %>%
group_by(event_lower) %>%
summarise(
n = n(),
Media = mean(potencia_kw),
Mediana = median(potencia_kw),
`Desv. Std` = sd(potencia_kw)
)
kable(stats_potencia,
caption = "Estadísticas de potencia por evento",
digits = 3,
booktabs = TRUE) %>%
kable_styling(latex_options = c("hold_position"), font_size = 10)
# Test estadístico
potencia_inter <- df_potencia %>% filter(event_lower == "interstation") %>% pull(potencia_kw)
potencia_stop <- df_potencia %>% filter(event_lower == "stop") %>% pull(potencia_kw)
test_potencia <- wilcox.test(potencia_inter, potencia_stop)
df_filtered <- df_filtered %>%
mutate(date = as.Date(date_time),
dia_mes = day(date))
df_train <- df_filtered %>% filter(dia_mes <= 15)
df_test <- df_filtered %>% filter(dia_mes > 15)
modelo_lineal <- lm(eaux_train_ac ~ event_duration + suma_ton_compresores +
suma_hvac_ton_compresores + suma_hvac_ton_heater +
suma_ton_comp_cab + suma_ton_heater_cab,
data = df_train)
# Tabla de coeficientes
coef_table <- tidy(modelo_lineal) %>%
mutate(
p_formatted = ifelse(p.value < 0.001,
sprintf("%.2e", p.value),
sprintf("%.4f", p.value)),
sig = case_when(
p.value < 0.001 ~ "***",
p.value < 0.01 ~ "**",
p.value < 0.05 ~ "*",
TRUE ~ ""
)
)
kable(coef_table %>% select(term, estimate, std.error, statistic, p_formatted, sig),
caption = "Coeficientes del modelo de regresión lineal",
digits = 6,
col.names = c("Variable", "Estimación", "Error Est.", "t-stat", "p-valor", "Sig."),
booktabs = TRUE) %>%
kable_styling(latex_options = c("hold_position", "scale_down"), font_size = 8)
kable(coef_table %>% select(term, estimate, std.error, statistic, p_formatted, sig),
caption = "Coeficientes del modelo de regresión lineal",
digits = 6,
col.names = c("Variable", "Estimación", "Error Est.", "t-stat", "p-valor", "Sig."),
booktabs = TRUE) %>%
kable_styling(latex_options = c("hold_position", "scale_down"), font_size = 8)
r2 <- summary(modelo_lineal)$r.squared
r2_adj <- summary(modelo_lineal)$adj.r.squared
vars_no_sig <- coef_table %>% filter(p.value >= 0.05, term != "(Intercept)")
vars_sig <- coef_table %>%
filter(p.value < 0.05, term != "(Intercept)") %>%
select(Variable = term, `p-valor` = p.value)
kable(vars_sig,
caption = "Variables significativas del modelo",
digits = 6,
booktabs = TRUE) %>%
kable_styling(latex_options = c("hold_position"), font_size = 10)
